@model IEnumerable<RiskAnalyzer.Models.InputCriteriaModel>

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>Критерии за оценка</h2>
        <a asp-action="Add" class="btn btn-primary">Нов Критерий</a>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Име на критерия</th>
                <th>Тежест (Weight)</th>
                <th style="width: 200px;">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td><span class="badge bg-info text-dark">@item.Weight</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редактирай</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Сигурен ли си?')">Изтрий</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>