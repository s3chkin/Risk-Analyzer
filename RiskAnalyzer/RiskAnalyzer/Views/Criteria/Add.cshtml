@model RiskAnalyzer.Models.InputCriteriaModel

<div class="container mt-4">
    <div class="card shadow" style="max-width: 500px; margin: auto;">
        <div class="card-header bg-success text-white">
            <h4>Добави Критерий</h4>
        </div>
        <div class="card-body">
            <form asp-action="Add" method="post">
                <div class="mb-3">
                    <label class="form-label">Име на критерия</label>
                    <input asp-for="Name" class="form-control" placeholder="напр. Финансов риск" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Тежест (1-10)</label>
                    <input asp-for="Weight" type="number" class="form-control" min="1" max="10" value="5" />
                    <small class="text-muted">10 е най-важно, 1 е най-малко важно.</small>
                </div>
                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-success">Запази</button>
                    <a asp-action="Index" class="btn btn-secondary">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</div>