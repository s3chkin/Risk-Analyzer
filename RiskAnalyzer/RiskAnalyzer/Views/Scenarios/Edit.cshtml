@model RiskAnalyzer.Models.InputScenariosModel

<div class="container mt-4">
    <div class="card shadow border-warning">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0">Редактиране на сценарий #@Model.Id</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label font-weight-bold">Заглавие</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label">Локация</label>
                        <input asp-for="Location" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="RiskTypeId" class="form-label">Тип на риска</label>
                        <select asp-for="RiskTypeId" asp-items="Model.RiskTypes" class="form-select"></select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CreatedAt" class="form-label">Дата</label>
                        <input asp-for="CreatedAt" type="datetime-local" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Status" class="form-label">Статус</label>
                        <select asp-for="Status" class="form-select">
                            <option value="New">Нов</option>
                            <option value="In Progress">В процес на анализ</option>
                            <option value="Resolved">Разрешен</option>
                        </select>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-primary">Обнови данните</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Обратно към списъка</a>
                </div>
            </form>
        </div>
    </div>
</div>